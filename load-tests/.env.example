# Copy to .env and fill in (or export in shell). .env is gitignored.
# k6 does not auto-load .env — use: export $(cat .env | xargs) && k6 run dispatcher-session.js

BASE_URL=https://your-gateway.azurecontainerapps.io
K6_LOGIN_EMAIL=
K6_LOGIN_PASSWORD=

# Optional — must exist in QA DB for POST /assignment/api/assignments
DELIVERY_ID=1
VEHICLE_ID=1
DRIVER_ID=1

# Report load test (load-tests/report-generation.js)
# K6_REPORT_AUTH_MODE=setup
# K6_REPORT_VARIANT=r2
# K6_REPORT_VUS=2
# K6_REPORT_EXECUTOR=ramping
# K6_REPORT_RAMP_DURATION=30s
# K6_REPORT_HOLD_DURATION=90s
# K6_REPORT_DURATION=90s
# K6_REPORT_LOGIN_TIMEOUT=90s
# K6_REPORT_HTTP_TIMEOUT=120s
# K6_REPORT_SETUP_TIMEOUT=120s
# K6_REPORT_GRACEFUL_STOP=120s
# K6_REPORT_MAX_FAIL_RATE=0.5
# MER_REPORT_START_UTC=2026-01-01T00:00:00Z
# MER_REPORT_END_UTC=2026-04-01T23:59:59Z
# Path segments (must match ReportsController + gateway): delivery-success, vehicle-utilization, driver-performance
# MER_REPORT_SEGMENT_DELIVERY=delivery-success
# MER_REPORT_SEGMENT_VEHICLE=vehicle-utilization
# MER_REPORT_SEGMENT_DRIVER=driver-performance
