{
  "info": {
    "_postman_id": "9e1d8d5b-7c7b-4d9e-9c8b-1b0b6a2c0001",
    "name": "Meridian Backend (All Services)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection for Meridian API Gateway + all microservices: UserService, DeliveryService, VehicleService, DriverService, AssignmentService, RouteService, TrackingService. Routes are primarily exercised via the API Gateway (default http://localhost:5050)."
  },
  "item": [
    {
      "name": "UserService (via Gateway)",
      "item": [
        {
          "name": "Register (POST /api/auth/register)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Postman Admin\",\n  \"email\": \"postman.admin@example.com\",\n  \"password\": \"P@ssw0rd!\",\n  \"role\": \"Admin\"\n}"
            },
            "url": {
              "raw": "{{gatewayBaseUrl}}/api/auth/register",
              "host": [ "{{gatewayBaseUrl}}" ],
              "path": [ "api", "auth", "register" ]
            }
          }
        },
        {
          "name": "Login (POST /api/auth/login) — sets tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  if (json && json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman.admin@example.com\",\n  \"password\": \"P@ssw0rd!\"\n}"
            },
            "url": {
              "raw": "{{gatewayBaseUrl}}/api/auth/login",
              "host": [ "{{gatewayBaseUrl}}" ],
              "path": [ "api", "auth", "login" ]
            }
          }
        },
        {
          "name": "Refresh (POST /api/auth/refresh) — sets tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  if (json && json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{gatewayBaseUrl}}/api/auth/refresh",
              "host": [ "{{gatewayBaseUrl}}" ],
              "path": [ "api", "auth", "refresh" ]
            }
          }
        },
        {
          "name": "Revoke (POST /api/auth/revoke) [Authorize]",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{gatewayBaseUrl}}/api/auth/revoke",
              "host": [ "{{gatewayBaseUrl}}" ],
              "path": [ "api", "auth", "revoke" ]
            }
          }
