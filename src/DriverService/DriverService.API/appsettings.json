{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ports": {
    "DriverServiceHttp": 6003,
    "DriverServiceGrpc": 7003
  },
  "ConnectionStrings": {
    "DriverDb": ""
  },
  "Reporting": {
    "DeliveryDatabaseName": "meridian_delivery"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "meridian-gateway",
    "Audience": "meridian-api"
  }
}
