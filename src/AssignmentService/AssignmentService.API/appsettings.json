{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AssignmentDb": ""
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/meridian",
    "Audience": "meridian-api"
  },
  "Grpc": {
    "VehicleServiceUrl": "http://localhost:6002",
    "DriverServiceUrl": "http://localhost:6003"
  }
}