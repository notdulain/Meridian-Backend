# Copy this file to local-k6.env before rehearsal.
# k6 does not auto-load .env files; the ASE wrapper scripts source this file for you.

BASE_URL=http://localhost:5050
K6_LOGIN_EMAIL=dispatcher@example.com
K6_LOGIN_PASSWORD=ChangeMe123!

# Use either the single IDs below or provide pools with the plural forms.
DELIVERY_ID=1
VEHICLE_ID=1
DRIVER_ID=1
# DELIVERY_IDS=1,2,3
# VEHICLE_IDS=1,2,3
# DRIVER_IDS=1,2,3

# ASE local dispatcher smoke defaults
K6_DISPATCHER_PROFILE=demo
K6_ASSIGNMENT_NOTES='ASE local smoke'
# K6_ASSIGNMENT_DURATION=5s

# ASE local report smoke defaults
K6_REPORT_PROFILE=demo
K6_REPORT_VARIANT=r1
K6_REPORT_AUTH_MODE=setup

# Optional local report filter window
# MER_REPORT_START_UTC=2026-01-01T00:00:00Z
# MER_REPORT_END_UTC=2026-04-01T23:59:59Z
